# Dependencies (installed fresh at build time via npm + package-lock.json)
node_modules/

# Build output (regenerated by `npm run build`)
dist/

# pnpm artifacts — this project builds with npm; a committed pnpm-lock.yaml /
# pnpm-workspace.yaml makes Nixpacks/Railway pick pnpm and fail the build.
pnpm-lock.yaml
pnpm-workspace.yaml

# Transient SQLite write-ahead log / shared-memory files (the .db is tracked)
server/storage/*.db-wal
server/storage/*.db-shm

# Local env files (keep the *.example templates)
.env
.env.local
.env.*.local

# OS / editor cruft
.DS_Store
*.log

# Unity generated folders (matches Unity/... and nested Unity/<project>/...)
Unity/**/[Ll]ibrary/
Unity/**/[Tt]emp/
Unity/**/[Oo]bj/
Unity/**/[Bb]uild/
Unity/**/[Bb]uilds/
Unity/**/[Ll]ogs/
Unity/**/[Uu]ser[Ss]ettings/
Unity/**/[Mm]emoryCaptures/
Unity/**/[Rr]ecordings/

# IDE
.vscode/
.idea/

# OS
Thumbs.db
