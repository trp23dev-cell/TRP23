#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/richard-t-martin/TRP23/node_modules/.pnpm/native-run@2.0.3/node_modules/native-run/node_modules:/home/richard-t-martin/TRP23/node_modules/.pnpm/native-run@2.0.3/node_modules:/home/richard-t-martin/TRP23/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/richard-t-martin/TRP23/node_modules/.pnpm/native-run@2.0.3/node_modules/native-run/node_modules:/home/richard-t-martin/TRP23/node_modules/.pnpm/native-run@2.0.3/node_modules:/home/richard-t-martin/TRP23/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../native-run@2.0.3/node_modules/native-run/bin/native-run" "$@"
else
  exec node  "$basedir/../../../../../../native-run@2.0.3/node_modules/native-run/bin/native-run" "$@"
fi
